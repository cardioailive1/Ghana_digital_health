# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Auth (JWT + Session) ─────────────────────────────────────
JWT_SECRET=your-256-bit-random-secret-here
SESSION_SECRET=your-session-secret-here
JWT_EXPIRES_IN=8h
SESSION_MAX_AGE_MS=28800000

# ─── OAuth — Google Workspace (hospital SSO) ──────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── OAuth — Microsoft Azure AD (hospital AD) ─────────────────
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-client-secret
MICROSOFT_TENANT_ID=your-tenant-id-or-common

# ─── Database (PostgreSQL on Render) ──────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/cardio_ai

# ─── App URL (set to your Render domain) ──────────────────────
CLIENT_URL=https://cardio-ai-ghana.onrender.com

# ─── Security ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
ALLOWED_ORIGINS=https://cardio-ai-ghana.onrender.com

# ─── Prisma / PostgreSQL ──────────────────────────────────────
# On Render: create a PostgreSQL database, copy the "Internal Database URL"
# It looks like: postgresql://user:pass@hostname/dbname?sslmode=require
DATABASE_URL=postgresql://cardioai:password@host:5432/cardioai_ghana?sslmode=require
