{
  "name": "cardio-ai-ghana",
  "version": "3.0.0",
  "private": true,
  "description": "Cardio AI Ghana Digital Health Platform — Render.com deployment",
  "type": "module",
  "scripts": {
    "dev":        "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "client:dev": "vite",
    "server:dev": "node --watch server/index.js",
    "build":      "vite build",
    "start":      "node server/index.js",
    "preview":    "vite preview",
    "db:migrate": "npx prisma migrate deploy",
    "db:seed":    "node server/seed.js",
    "db:studio":  "npx prisma studio",
    "db:push":    "npx prisma db push",
    "postinstall": "npx prisma generate"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client":           "^5.15.0",
    "express":                  "^4.19.2",
    "express-rate-limit":       "^7.3.1",
    "express-session":          "^1.18.0",
    "helmet":                   "^7.1.0",
    "cors":                     "^2.8.5",
    "dotenv":                   "^16.4.5",
    "jsonwebtoken":              "^9.0.2",
    "bcryptjs":                  "^2.4.3",
    "passport":                  "^0.7.0",
    "passport-google-oauth20":   "^2.0.0",
    "passport-microsoft":        "^1.0.0",
    "uuid":                      "^10.0.0",
    "morgan":                    "^1.10.0",
    "winston":                   "^3.13.0",
    "validator":                 "^13.12.0",
    "hpp":                       "^0.2.3",
    "cookie-parser":             "^1.4.6",
    "react":                     "^18.3.1",
    "react-dom":                 "^18.3.1"
  },
  "devDependencies": {
    "prisma":               "^5.15.0",
    "@vitejs/plugin-react": "^4.3.1",
    "vite":                 "^5.4.0",
    "concurrently":         "^8.2.2"
  }
}
